# Copy to .env for real (non-mock) runs. Never commit .env.
# Dev/offline runs need none of these — use --provider mock (default).

# Real runs via Anthropic (BUILD_BRIEF recommends claude-sonnet-4-6 for prod):
ANTHROPIC_API_KEY=

# Gemini（無料/割当枠が大きい。google-genai SDK は GEMINI_API_KEY を読む）
GEMINI_API_KEY=

# Override the Python interpreter the Node bridge spawns (default: "python"):
# INTENTLOOP_PYTHON=python3
